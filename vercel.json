{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "apps/web/dist",
        "buildCommand": "npm run build --workspace=@cpv/web"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "apps/web/dist/assets/$1"
    },
    {
      "src": "/((?!api|assets).*\\.[^/]+)$",
      "dest": "apps/web/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "apps/web/dist/index.html"
    }
  ]
}
